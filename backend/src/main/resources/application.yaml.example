spring:
  application:
    name: backend

  servlet:
    multipart:
      max-file-size: 50MB
      max-request-size: 50MB

  datasource:
    url: jdbc:postgresql://localhost:5432/dev_track_ai?options=-c%20timezone=Asia/Ho_Chi_Minh
    username: postgres
    password: YOUR_DATABASE_PASSWORD_HERE # 👈 Điền mật khẩu database PostgreSQL local của bạn vào đây
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
        jdbc:
          lob:
            non_contextual_creation: true
    open-in-view: false

  flyway:
    enabled: true
    out-of-order: true
    baseline-on-migrate: true
    locations: classpath:db/migration

  # Redis - dùng cho OTP, Session, Cache
  # Đảm bảo Redis đang chạy trước khi khởi động backend (redis-server)
  data:
    redis:
      host: localhost
      port: 6379 # Port mặc định của Redis

  session:
    store-type: redis
    timeout: 30m # Session hết hạn sau 30 phút

  kafka:
    bootstrap-servers: localhost:9092
    producer:
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.apache.kafka.common.serialization.StringSerializer

  mail:
    host: smtp.gmail.com
    port: 587
    username: email_cua_ban@gmail.com # 👈 Điền Gmail thật của bạn vào đây để gửi email OTP
    password: mat_khau_ung_dung_16_ky_tu # 👈 Điền App Password 16 ký tự (không phải mật khẩu Gmail thường)
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
            required: true
          connectiontimeout: 5000
          timeout: 5000
          writetimeout: 5000

cloudinary:
  cloud-name: "YOUR_CLOUD_NAME_HERE"
  api-key: "YOUR_API_KEY_HERE"
  api-secret: "YOUR_API_SECRET_HERE"

app:
  events:
    # local = team members can run without Kafka; kafka = publish outbox events to Kafka topics
    publisher: local
    outbox-publish-delay-ms: 30000
